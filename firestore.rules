rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /kycVerifications/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin();
    }

    match /machines/{machineId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /deals/{dealId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.businessId == request.auth.uid);
    }

    match /investments/{invId} {
      allow read: if isSignedIn() && (resource.data.investorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.investorId == request.auth.uid;
    }

    match /waitlist/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
