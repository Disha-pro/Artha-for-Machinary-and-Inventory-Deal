rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // USERS
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && incoming().role == 'user';
      allow update: if isOwner(userId) && incoming().role == existing().role;
    }

    // PROFILES
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // KYC VERIFICATIONS (Highly Secure)
    match /kycVerifications/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && incoming().status == 'pending';
      allow update: if isAdmin(); // Only admins can verify or reject
    }

    // MACHINES
    match /machines/{machineId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // DEALS
    match /deals/{dealId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().status == 'draft';
      allow update: if isAdmin() || (isSignedIn() && incoming().businessId == existing().businessId && incoming().status == existing().status);
    }

    // INVESTMENTS
    match /investments/{investmentId} {
      allow read: if isSignedIn() && (resource.data.investorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().investorId == request.auth.uid;
    }

    // REVENUE REPORTS
    match /revenueReports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // WAITLIST
    match /waitlist/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
